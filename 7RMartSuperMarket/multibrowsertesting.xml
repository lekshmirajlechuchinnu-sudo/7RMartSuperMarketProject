<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBrowserTesting" parallel="tests">
  <test  name="ChromeTest">
  <parameter name="Browser" value="chrome"></parameter>
    <classes>
      <class name="testscript.LoginTest">
      <methods> 
      <include name="verifyTheUserIsAbleToLoginValidCredentials"></include>
      </methods>
      </class>
      <class name="testscript.AdminTest"></class>
      <class name="testscript.ManageCategoryTest"></class>
      <class name="testscript.ManageDeliveryBoyTest"></class>
      <class name="testscript.ManageNewsTest"></class>
      <class name="testscript.ManageOfferCodeTest"></class>
    </classes>
  </test>
  
  <test  name="FirefoxTest">
  <parameter name="Browser" value="firefox"></parameter>
    <classes>
      <class name="testscript.LoginTest">
      <methods> 
      <include name="verifyTheUserIsAbleToLoginValidCredentials"></include>
      </methods>
      </class>
      <class name="testscript.AdminTest"></class>
      <class name="testscript.ManageCategoryTest"></class>
      <class name="testscript.ManageDeliveryBoyTest"></class>
      <class name="testscript.ManageNewsTest"></class>
      <class name="testscript.ManageOfferCodeTest"></class>
    </classes>
  </test>
  
   <!-- Test -->
</suite> <!-- Suite -->
